{
    "name": "cydig-azure-tasks",
    "description": "cydig azure tasks",
    "version": "1.0.0",
    "author": "",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Omegapoint/CydigAzureComplianceAction.git"
    },
    "bugs": {
        "url": "https://github.com/Omegapoint/CydigAzureComplianceAction/issues"
    },
    "keywords": [
        "actions",
        "node",
        "setup"
    ],
    "exports": {
        ".": "./dist/index.js"
    },
    "engines": {
        "node": ">=20.19.0"
    },
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc && rollup -c",
        "test": "tsc && mocha dist/tests/",
        "testScript": "tsc && mocha dist/tests/ --reporter xunit --reporter-option output=ResultsFile.xml",
        "prepare": "husky",
        "lint": "npx eslint .",
        "lint:fix": "npx eslint . --fix",
        "format:write": "npx prettier -w .",
        "format:check": "npx prettier -c ."
    },
    "license": "MIT",
    "dependencies": {
        "@actions/core": "^3.0.0",
        "@azure/arm-authorization": "^9.0.0",
        "@azure/arm-compute": "^23.3.0",
        "@azure/arm-policy": "^6.0.0",
        "@azure/arm-policyinsights": "^5.0.0",
        "@azure/arm-security": "^5.0.0",
        "@azure/identity": "^4.13.1",
        "@microsoft/microsoft-graph-client": "^3.0.7",
        "isomorphic-fetch": "^3.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@rollup/plugin-commonjs": "^29.0.2",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^16.0.3",
        "@types/chai": "^5.2.3",
        "@types/isomorphic-fetch": "^0.0.39",
        "@types/mocha": "^10.0.10",
        "@types/node": "^25.5.0",
        "@types/sinon": "^21.0.0",
        "@types/sinon-chai": "^4.0.0",
        "chai": "^6.2.2",
        "eslint": "^10.1.0",
        "husky": "^9.1.7",
        "mocha": "^11.1.0",
        "prettier": "^3.8.1",
        "rollup": "^4.60.0",
        "sinon": "^21.0.3",
        "sinon-chai": "^4.0.1",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.1"
    }
}
